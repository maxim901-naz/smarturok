# Copy this file to .env on server and fill real values.

DJANGO_SECRET_KEY=replace-me-with-very-long-random-secret
DJANGO_DEBUG=False
DJANGO_TIME_ZONE=Europe/Moscow
DJANGO_ALLOWED_HOSTS=smarturok.ru,www.smarturok.ru
DJANGO_CSRF_TRUSTED_ORIGINS=https://smarturok.ru,https://www.smarturok.ru

DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_X_FRAME_OPTIONS=DENY
DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# Recommended: DATABASE_URL
DATABASE_URL=postgresql://maxschool_user:change-me@127.0.0.1:5432/maxschool_prod
DJANGO_DB_CONN_MAX_AGE=60
DJANGO_DB_SSLMODE=prefer

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
DJANGO_EMAIL_TIMEOUT=10
DJANGO_EMAIL_HOST_USER=smarturok.ru@gmail.com
DJANGO_EMAIL_HOST_PASSWORD=replace-with-gmail-app-password
DJANGO_DEFAULT_FROM_EMAIL=smarturok.ru@gmail.com
DJANGO_ADMIN_EMAIL=smarturok.ru@gmail.com

JAAAS_APP_ID=
JAAAS_KEY_ID=
JAAAS_PRIVATE_KEY_FILE=/opt/maxschool/keys/jaas_private_key.pem
JAAAS_DOMAIN=8x8.vc
JAAAS_JWT_ISSUER=chat

REDIS_URL=redis://127.0.0.1:6379/0

GA4_MEASUREMENT_ID=
YANDEX_METRIKA_COUNTER_ID=
META_PIXEL_ID=

WHITEBOARD_WS_MAX_MESSAGE_BYTES=2500000
WHITEBOARD_WS_MAX_IMAGE_DATA_URL_LENGTH=1500000
BOARD_STATE_MAX_REQUEST_BYTES=6000000
BOARD_STATE_MAX_SERIALIZED_BYTES=6000000
BOARD_STATE_MAX_BOARDS=40
BOARD_STATE_MAX_IMAGE_DATA_URL_LENGTH=1500000
